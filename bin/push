#!/usr/bin/env bash
set -euo pipefail

# Global git push helper. Run inside a git repo.

usage() {
  cat <<'USAGE'
Usage: push [-m "commit message"] [--no-notify]

Environment:
  FEISHU_WEBHOOK   Feishu bot webhook URL. If set, can send notify.
  PUSH_NOTIFY      If set to 1, auto-send notify without prompt.
  PUSH_LOCAL_HOOK  Path to local hook script (relative or absolute).
  PUSH_POST_HOOK   Path to post-push hook script (relative or absolute).
  PUSH_SKIP_BUMP   If set to 1, skip version bump prompt.

Local pre-hook search order (first match):
  1) $PUSH_LOCAL_HOOK
  2) ./.push.local.sh
  3) ./scripts/push.local.sh

Local post-hook search order (first match):
  1) $PUSH_POST_HOOK
  2) ./.push.post.sh
  3) ./scripts/push.post.sh
USAGE
}

commit_message=""
notify_flag="auto"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -m|--message)
      commit_message="${2:-}"
      shift 2
      ;;
    --no-notify)
      notify_flag="no"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown arg: $1"
      usage
      exit 2
      ;;
  esac
done

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || true)
if [[ -z "${repo_root}" ]]; then
  echo "当前目录不是 git 仓库"
  exit 1
fi

cd "$repo_root"

# --- 部署名称/服务名处理 ---
# .deploy-service: 用于 deploy 默认服务名（推荐）
# .deploy-name: 兼容历史用法（审批文案等）
# .deploy-path: 用于 deploy 默认 path（可为空）
deploy_service_file=".deploy-service"
deploy_name_file=".deploy-name"
deploy_path_file=".deploy-path"
reconfigure_deploy=0

# 历史兼容：旧版本会把部署配置写入 .gitignore，导致不同项目/分支共享本地配置。
# 现在统一移除这些忽略项，并在本次 push 中重新询问配置。
if [[ -f ".gitignore" ]]; then
  gitignore_tmp=$(mktemp)
  awk -v s="$deploy_service_file" -v n="$deploy_name_file" -v p="$deploy_path_file" '
    $0 == s || $0 == n || $0 == p { next }
    { print }
  ' ".gitignore" > "$gitignore_tmp"

  if ! cmp -s ".gitignore" "$gitignore_tmp"; then
    mv "$gitignore_tmp" ".gitignore"
    reconfigure_deploy=1
    echo "已从 .gitignore 移除旧部署忽略项: $deploy_service_file, $deploy_name_file, $deploy_path_file"
  else
    rm -f "$gitignore_tmp"
  fi
fi

if [[ "$reconfigure_deploy" == "1" ]]; then
  current_deploy_name=""
  if [[ -f "$deploy_service_file" ]]; then
    current_deploy_name=$(cat "$deploy_service_file")
  elif [[ -f "$deploy_name_file" ]]; then
    current_deploy_name=$(cat "$deploy_name_file")
  fi
  echo "检测到历史忽略配置，为避免部署名称冲突，请重新确认。"
  read -r -p "请输入项目部署名 (当前: ${current_deploy_name:-未配置}，直接回车保持不变): " input_name
  if [[ -n "$input_name" ]]; then
    echo "$input_name" > "$deploy_service_file"
    echo "$input_name" > "$deploy_name_file"
    deploy_name="$input_name"
  else
    deploy_name="${current_deploy_name:-$(basename "$repo_root")}"
    echo "$deploy_name" > "$deploy_service_file"
    echo "$deploy_name" > "$deploy_name_file"
  fi
elif [[ -f "$deploy_service_file" ]]; then
  deploy_name=$(cat "$deploy_service_file")
elif [[ -f "$deploy_name_file" ]]; then
  deploy_name=$(cat "$deploy_name_file")
else
  echo "检测到尚未配置部署名称。"
  read -r -p "请输入项目部署名 (可以lookup搜索域名对应的scmp项目名): " input_name
  if [[ -n "$input_name" ]]; then
    echo "$input_name" > "$deploy_service_file"
    echo "$input_name" > "$deploy_name_file"
    deploy_name="$input_name"
  else
    deploy_name=$(basename "$repo_root")
  fi
fi

# 若读取到的是旧文件，自动补写新文件，便于 deploy 默认读取。
if [[ -n "${deploy_name:-}" && ! -f "$deploy_service_file" ]]; then
  echo "$deploy_name" > "$deploy_service_file"
fi

# path 首次录入（含历史项目补录）：
# 仅在 .deploy-path 文件不存在时触发；可输入空值，但必须走一次输入步骤。
if [[ "$reconfigure_deploy" == "1" || ! -f "$deploy_path_file" ]]; then
  echo "请确认本项目是否需要执行上传命令。"
  current_deploy_path=""
  if [[ -f "$deploy_path_file" ]]; then
    current_deploy_path=$(cat "$deploy_path_file")
  fi
  read -r -p "请输入部署 path (可留空；当前: ${current_deploy_path}，直接回车保持不变): " input_path
  echo "${input_path}" > "$deploy_path_file"
fi

project_name=$(basename "$repo_root")
current_branch=$(git symbolic-ref --short HEAD)

# ----- version increment (generic) -----
increment_version() {
  local branch=$1
  local format_type=$2

  local pattern_standard="([0-9]+\\.[0-9]+)\\.([0-9]+)"
  local pattern_extended="([0-9]+\\.[0-9]+\\.[0-9]+)\\.([0-9]+)"
  local pattern_three_parts="([0-9]+\\.[0-9]+\\.[0-9]+)$"
  local pattern_two_parts="([0-9]+\\.[0-9]+)$"

  if [[ $format_type == "extended" && $branch =~ $pattern_extended ]]; then
    local main_version="${BASH_REMATCH[1]}"
    local sub_version="${BASH_REMATCH[2]}"
    local new_sub_version=$((sub_version + 1))
    echo "${main_version}.${new_sub_version}"
  elif [[ $format_type == "auto" && $branch =~ $pattern_extended ]]; then
    local main_version="${BASH_REMATCH[1]}"
    local sub_version="${BASH_REMATCH[2]}"
    local new_sub_version=$((sub_version + 1))
    echo "${main_version}.${new_sub_version}"
  elif [[ $format_type == "extended" && $branch =~ $pattern_three_parts ]]; then
    echo "${branch}.1"
  elif [[ $format_type != "extended" && $branch =~ $pattern_standard ]]; then
    local main_version="${BASH_REMATCH[1]}"
    local sub_version="${BASH_REMATCH[2]}"
    local new_sub_version=$((sub_version + 1))
    echo "${main_version}.${new_sub_version}"
  elif [[ $format_type == "extended" && $branch =~ $pattern_two_parts ]]; then
    echo "${branch}.0.1"
  elif [[ $branch =~ $pattern_two_parts ]]; then
    echo "${branch}.1"
  else
    echo "${branch}"
  fi
}

old_branch="$current_branch"
project_prefix=""
version_part=""

if [[ $current_branch =~ ^(.+)-([0-9]+\.[0-9]+.*)$ ]]; then
  project_prefix="${BASH_REMATCH[1]}"
  version_part="${BASH_REMATCH[2]}"
else
  version_part="$current_branch"
fi

if [[ "${PUSH_SKIP_BUMP:-0}" != "1" && $current_branch =~ [0-9]+\.[0-9]+ ]]; then
  echo "当前分支: $current_branch"
  echo "请选择版本号格式:"
  echo "1. 标准格式 (x.x.y)"
  echo "2. 扩展格式 (x.x.x.y) [默认]"
  read -r -p "请选择版本号格式(1/2): " version_format_choice

  version_format_choice=${version_format_choice:-2}
  if [[ "$version_format_choice" == "1" ]]; then
    version_format="standard"
  else
    version_format="extended"
  fi

  new_version_part=$(increment_version "$version_part" "$version_format")
  if [[ -n "$project_prefix" ]]; then
    new_branch_name="${project_prefix}-${new_version_part}"
  else
    new_branch_name="$new_version_part"
  fi

  echo "建议新分支: $new_branch_name"
  read -r -p "是否使用新版本号(1/2)[默认1]: " use_new_version
  use_new_version=${use_new_version:-1}
  if [[ "$use_new_version" == "1" ]]; then
    git checkout -b "$new_branch_name"
    current_branch="$new_branch_name"
  fi
fi

# Local pre-hook (project specific changes)
pre_hook_path=""
if [[ -n "${PUSH_LOCAL_HOOK:-}" ]]; then
  pre_hook_path="$PUSH_LOCAL_HOOK"
elif [[ -f ".push.local.sh" ]]; then
  pre_hook_path=".push.local.sh"
elif [[ -f "scripts/push.local.sh" ]]; then
  pre_hook_path="scripts/push.local.sh"
fi

if [[ -n "$pre_hook_path" ]]; then
  if [[ "$pre_hook_path" != /* ]]; then
    pre_hook_path="$repo_root/$pre_hook_path"
  fi
  echo "执行本地 Pre Hook: $pre_hook_path"
  if [[ -x "$pre_hook_path" ]]; then
    "$pre_hook_path" "$repo_root" "$current_branch" "$project_name" "$old_branch"
  else
    bash "$pre_hook_path" "$repo_root" "$current_branch" "$project_name" "$old_branch"
  fi
fi

# Stage all changes
if ! git diff --quiet || ! git diff --cached --quiet; then
  git add -A
fi

# Commit if there are staged changes
if git diff --cached --quiet; then
  echo "没有可提交的变更"
else
  if [[ -z "$commit_message" ]]; then
    read -r -p "请输入提交信息: " commit_message
  fi
  if [[ -z "$commit_message" ]]; then
    echo "提交信息不能为空"
    exit 1
  fi
  git commit -m "$commit_message"
fi

# Push
if git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
  git push
else
  git push -u origin "$current_branch"
fi

# Collect changed files from last commit (if any)
changed_files=""
if git rev-parse HEAD~1 >/dev/null 2>&1; then
  changed_files=$(git diff --name-only HEAD~1 HEAD | tr '\n' ',' | sed 's/,$//')
fi

# Notify (Feishu)
if [[ -n "${FEISHU_WEBHOOK:-}" && "$notify_flag" != "no" ]]; then
  if [[ "${PUSH_NOTIFY:-0}" != "1" ]]; then
    read -r -p "是否发送飞书通知? (y/N): " notify_choice
    if [[ "${notify_choice}" != "y" && "${notify_choice}" != "Y" ]]; then
      notify_choice=""
    fi
  else
    notify_choice="y"
  fi

  if [[ -n "$notify_choice" ]]; then
    notify_content="${commit_message:-已推送}"
    curl -sS -X POST -H "Content-Type: application/json" \
      -d "{\"msg_type\": \"text\", \"content\": {\"text\": \"🚀 推送通知\\n项目: ${project_name}\\n分支: ${current_branch}\\n提交信息: ${commit_message:-无}\\n更新文件: ${changed_files}\"}}" \
      "$FEISHU_WEBHOOK" >/dev/null
    echo "飞书通知已发送"
  fi
fi

# Local post-hook (optional)
post_hook_path=""
if [[ -n "${PUSH_POST_HOOK:-}" ]]; then
  post_hook_path="$PUSH_POST_HOOK"
elif [[ -f ".push.post.sh" ]]; then
  post_hook_path=".push.post.sh"
elif [[ -f "scripts/push.post.sh" ]]; then
  post_hook_path="scripts/push.post.sh"
fi

if [[ -n "$post_hook_path" ]]; then
  if [[ "$post_hook_path" != /* ]]; then
    post_hook_path="$repo_root/$post_hook_path"
  fi
  echo "执行本地 Post Hook: $post_hook_path"
  if [[ -x "$post_hook_path" ]]; then
    "$post_hook_path" "$repo_root" "$current_branch" "$project_name" "$old_branch"
  else
    bash "$post_hook_path" "$repo_root" "$current_branch" "$project_name" "$old_branch"
  fi
fi
