#!/bin/bash
# Figma MCP 服务管理工具

MCP_SERVER_PATH="/Users/xin/ImagePrepMCP/figma-smart-image-mcp/dist/server.js"
PORT=3845
PID_FILE="$HOME/.figmamcp.pid"
LOG_FILE="$HOME/figma-mcp.log"

case "$1" in
    start)
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE")
            if kill -0 $PID 2>/dev/null; then
                echo "Figma MCP服务已在运行 (PID: $PID)"
                exit 0
            else
                rm "$PID_FILE"
            fi
        fi
        
        echo "正在启动Figma MCP服务..."
        nohup node "$MCP_SERVER_PATH" --transport=http --port=$PORT > "$LOG_FILE" 2>&1 &
        
        PID=$!
        echo $PID > "$PID_FILE"
        
        if kill -0 $PID 2>/dev/null; then
            echo "Figma MCP服务已在后台启动，PID: $PID"
            echo "服务地址: http://localhost:$PORT"
        else
            echo "启动失败"
            rm "$PID_FILE"
            exit 1
        fi
        ;;
    stop)
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE")
            if kill -0 $PID 2>/dev/null; then
                kill $PID
                rm "$PID_FILE"
                echo "Figma MCP服务已停止 (PID: $PID)"
            else
                echo "进程未运行或已不存在"
                rm "$PID_FILE"
            fi
        else
            echo "服务未在运行"
        fi
        ;;
    restart)
        $0 stop
        sleep 2
        $0 start
        ;;
    status)
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE")
            if kill -0 $PID 2>/dev/null; then
                echo "Figma MCP服务正在运行 (PID: $PID)"
                echo "服务地址: http://localhost:$PORT"
            else
                echo "PID文件存在但进程不在运行"
                rm "$PID_FILE"
            fi
        else
            echo "Figma MCP服务未运行"
        fi
        ;;
    log)
        if [ -f "$LOG_FILE" ]; then
            tail -n 20 "$LOG_FILE"
        else
            echo "日志文件不存在"
        fi
        ;;
    *)
        echo "用法: $0 {start|stop|restart|status|log}"
        echo "  start   - 启动Figma MCP服务"
        echo "  stop    - 停止Figma MCP服务" 
        echo "  restart - 重启Figma MCP服务"
        echo "  status  - 查看服务状态"
        echo "  log     - 查看最近的日志"
        exit 1
        ;;
esac
