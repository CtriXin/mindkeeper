# agent-im configuration
# Copy to ~/.agent-im/config.env and fill in values

# ── Discord ──
AGENT_IM_DISCORD_BOT_TOKEN=
AGENT_IM_DISCORD_HUB_CHANNEL_ID=
AGENT_IM_DISCORD_ALLOWED_USERS=

# ── General ──
# Filter level for new sessions: full | summary | silent
AGENT_IM_DEFAULT_FILTER=summary
# Auto-archive thread after session ends (hours)
AGENT_IM_AUTO_ARCHIVE_HOURS=24
# Heartbeat check interval (ms)
AGENT_IM_HEARTBEAT_INTERVAL_MS=30000
